<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🔮 Team Dashboard - <%= teamId ? 'Loading...' : 'Team' %></title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
            color: white;
            min-height: 100vh;
            padding: 20px;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
        }

        .header {
            text-align: center;
            margin-bottom: 40px;
        }

        .header h1 {
            font-size: 2.5rem;
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        }

        .header p {
            font-size: 1.1rem;
            opacity: 0.9;
        }

        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .card {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border-radius: 15px;
            padding: 25px;
            border: 1px solid rgba(255, 255, 255, 0.2);
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);
        }

        .card h2 {
            color: #ffd700;
            margin-bottom: 20px;
            font-size: 1.5rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .card h3 {
            color: #ffd700;
            margin-bottom: 15px;
            font-size: 1.2rem;
        }

        .stat-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            margin-top: 15px;
        }

        .stat-item {
            background: rgba(255, 255, 255, 0.1);
            padding: 15px;
            border-radius: 8px;
            text-align: center;
        }

        .stat-number {
            font-size: 2rem;
            font-weight: bold;
            color: #ffd700;
            display: block;
            margin-bottom: 5px;
        }

        .stat-label {
            font-size: 0.9rem;
            opacity: 0.8;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .info-row:last-child {
            border-bottom: none;
        }

        .info-label {
            color: #ffd700;
            font-weight: 500;
        }

        .btn {
            padding: 10px 20px;
            border-radius: 8px;
            border: none;
            font-size: 0.95rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s;
            text-decoration: none;
            display: inline-block;
        }

        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
        }

        .btn-secondary {
            background: rgba(255, 255, 255, 0.2);
            color: white;
            margin-left: 10px;
        }

        .btn-secondary:hover {
            background: rgba(255, 255, 255, 0.3);
        }

        .nav-links {
            text-align: center;
            margin-top: 30px;
        }

        .nav-links a {
            color: #ffd700;
            text-decoration: none;
            margin: 0 15px;
            font-size: 1rem;
        }

        .nav-links a:hover {
            text-decoration: underline;
        }

        .chart-container {
            position: relative;
            height: 300px;
            margin-top: 20px;
        }

        .member-list {
            list-style: none;
        }

        .member-item {
            background: rgba(255, 255, 255, 0.05);
            padding: 12px;
            border-radius: 8px;
            margin-bottom: 8px;
        }

        .member-name {
            font-weight: 500;
            color: #ffd700;
        }

        .member-email {
            font-size: 0.9rem;
            opacity: 0.8;
        }

        .category-list {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 10px;
        }

        .category-badge {
            background: rgba(255, 255, 255, 0.1);
            padding: 8px 12px;
            border-radius: 6px;
            text-align: center;
            font-size: 0.9rem;
        }

        .category-badge.enabled {
            background: rgba(0, 255, 0, 0.2);
            border: 1px solid rgba(0, 255, 0, 0.3);
        }

        .category-badge.disabled {
            background: rgba(255, 0, 0, 0.2);
            border: 1px solid rgba(255, 0, 0, 0.3);
            opacity: 0.6;
        }

        .loading {
            text-align: center;
            padding: 40px;
            font-size: 1.2rem;
        }

        .error {
            background: rgba(255, 0, 0, 0.2);
            border: 1px solid rgba(255, 0, 0, 0.4);
            padding: 20px;
            border-radius: 10px;
            text-align: center;
        }

        .planetary-preview {
            background: rgba(255, 255, 255, 0.05);
            padding: 15px;
            border-radius: 8px;
            margin-top: 15px;
        }

        .planetary-item {
            padding: 8px 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .planetary-item:last-child {
            border-bottom: none;
        }

        .planet-symbol {
            font-size: 1.2rem;
            margin-right: 8px;
        }

        .action-buttons {
            display: flex;
            gap: 10px;
            margin-top: 20px;
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🔮 Team Dashboard</h1>
            <p id="teamNameHeader">Loading team information...</p>
        </div>

        <div id="loadingIndicator" class="loading">
            Loading team data...
        </div>

        <div id="errorContainer" style="display: none;"></div>

        <div id="dashboardContent" style="display: none;">
            <!-- Team Profile & Settings -->
            <div class="dashboard-grid">
                <div class="card">
                    <h2>📋 Team Profile</h2>
                    <div id="teamProfile"></div>
                    <div class="action-buttons">
                        <button class="btn btn-primary" onclick="editTeam()">Edit Settings</button>
                    </div>
                </div>

                <div class="card">
                    <h2>👥 Team Members</h2>
                    <ul id="membersList" class="member-list"></ul>
                    <div class="action-buttons">
                        <button class="btn btn-secondary" onclick="manageMembers()">Manage Members</button>
                    </div>
                </div>

                <div class="card">
                    <h2>🚨 Incident Categories</h2>
                    <div id="categoriesList" class="category-list"></div>
                </div>
            </div>

            <!-- Analytics -->
            <div class="dashboard-grid">
                <div class="card">
                    <h2>📊 Incident Statistics</h2>
                    <div id="incidentStats" class="stat-grid"></div>
                </div>

                <div class="card">
                    <h2>📈 Incidents Over Time</h2>
                    <div class="chart-container">
                        <canvas id="incidentChart"></canvas>
                    </div>
                </div>
            </div>

            <!-- Horoscope Preview -->
            <div class="card">
                <h2>🔮 Today's Role-Based Horoscope Preview</h2>
                <div id="horoscopePreview"></div>
                <div class="action-buttons">
                    <button class="btn btn-primary" onclick="refreshHoroscope()">Refresh Horoscope</button>
                </div>
            </div>

            <!-- Planetary Events -->
            <div class="card">
                <h2>🌟 Upcoming Planetary Events (Next 30 Days)</h2>
                <div id="planetaryEvents" class="planetary-preview"></div>
            </div>
        </div>

        <div class="nav-links">
            <a href="/">← Back to Main Dashboard</a>
            <a href="/team/setup">Create New Team</a>
            <a href="/team/list">View All Teams</a>
        </div>
    </div>

    <script>
        const teamId = '<%= teamId %>';
        let teamData = null;
        let analyticsData = null;

        async function loadTeamData() {
            try {
                const response = await fetch(`/api/teams/${teamId}`);
                if (!response.ok) throw new Error('Team not found');

                teamData = await response.json();
                displayTeamData();

                // Load analytics
                const analyticsResponse = await fetch(`/api/teams/${teamId}/analytics`);
                if (analyticsResponse.ok) {
                    analyticsData = await response.json();
                    displayAnalytics();
                }

                // Load horoscope preview
                await loadHoroscopePreview();

                document.getElementById('loadingIndicator').style.display = 'none';
                document.getElementById('dashboardContent').style.display = 'block';
            } catch (error) {
                console.error('Error loading team data:', error);
                document.getElementById('loadingIndicator').style.display = 'none';
                document.getElementById('errorContainer').innerHTML = `
                    <div class="error">
                        <h2>Error Loading Team</h2>
                        <p>${error.message}</p>
                        <button class="btn btn-primary" onclick="window.location.href='/team/list'">View All Teams</button>
                    </div>
                `;
                document.getElementById('errorContainer').style.display = 'block';
            }
        }

        function displayTeamData() {
            const { team, members, incident_categories, slack_workspaces } = teamData;

            // Update header
            document.getElementById('teamNameHeader').textContent = team.name;

            // Team profile
            const profileHtml = `
                <div class="info-row">
                    <span class="info-label">Team Name:</span>
                    <span>${team.name}</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Description:</span>
                    <span>${team.description || 'N/A'}</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Primary Role:</span>
                    <span>${team.primary_role || 'N/A'}</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Timezone:</span>
                    <span>${team.timezone}</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Language/Tone:</span>
                    <span>${team.language_tone}</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Daily Horoscope:</span>
                    <span>${team.daily_horoscope_enabled ? '✅ Enabled' : '❌ Disabled'}</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Delivery Time:</span>
                    <span>${team.delivery_time}</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Slack Workspaces:</span>
                    <span>${slack_workspaces.length} linked</span>
                </div>
            `;
            document.getElementById('teamProfile').innerHTML = profileHtml;

            // Team members
            if (members.length === 0) {
                document.getElementById('membersList').innerHTML = '<li class="member-item">No members added yet</li>';
            } else {
                const membersHtml = members.map(member => `
                    <li class="member-item">
                        <div class="member-name">${member.name}</div>
                        <div class="member-email">${member.email}</div>
                        ${member.role ? `<div class="member-role">${member.role}</div>` : ''}
                    </li>
                `).join('');
                document.getElementById('membersList').innerHTML = membersHtml;
            }

            // Incident categories
            const categoriesHtml = incident_categories.map(cat => `
                <div class="category-badge ${cat.enabled ? 'enabled' : 'disabled'}">
                    ${cat.enabled ? '✅' : '❌'} ${cat.category}
                </div>
            `).join('');
            document.getElementById('categoriesList').innerHTML = categoriesHtml || '<p>No categories configured</p>';
        }

        function displayAnalytics() {
            if (!analyticsData) return;

            // Display incident stats
            const stats = analyticsData.incident_stats || [];
            const totalIncidents = stats.reduce((sum, stat) => sum + parseInt(stat.total_incidents || 0), 0);
            const criticalCount = stats.reduce((sum, stat) => sum + parseInt(stat.critical_count || 0), 0);
            const highCount = stats.reduce((sum, stat) => sum + parseInt(stat.high_count || 0), 0);
            const mediumCount = stats.reduce((sum, stat) => sum + parseInt(stat.medium_count || 0), 0);

            const statsHtml = `
                <div class="stat-item">
                    <span class="stat-number">${totalIncidents}</span>
                    <span class="stat-label">Total Incidents</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number">${criticalCount}</span>
                    <span class="stat-label">Critical</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number">${highCount}</span>
                    <span class="stat-label">High</span>
                </div>
                <div class="stat-item">
                    <span class="stat-number">${mediumCount}</span>
                    <span class="stat-label">Medium</span>
                </div>
            `;
            document.getElementById('incidentStats').innerHTML = statsHtml;

            // Create chart
            createIncidentChart(analyticsData.incidents_over_time || []);
        }

        function createIncidentChart(data) {
            const ctx = document.getElementById('incidentChart');
            if (!ctx) return;

            // Group data by date
            const dates = [...new Set(data.map(d => d.date))].sort();
            const severities = ['critical', 'high', 'medium', 'low'];

            const datasets = severities.map(severity => {
                const color = {
                    critical: 'rgb(255, 99, 132)',
                    high: 'rgb(255, 159, 64)',
                    medium: 'rgb(255, 205, 86)',
                    low: 'rgb(75, 192, 192)'
                }[severity];

                return {
                    label: severity.charAt(0).toUpperCase() + severity.slice(1),
                    data: dates.map(date => {
                        const item = data.find(d => d.date === date && d.severity === severity);
                        return item ? parseInt(item.count) : 0;
                    }),
                    backgroundColor: color,
                    borderColor: color,
                    borderWidth: 1
                };
            });

            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: dates,
                    datasets: datasets
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        x: { stacked: true },
                        y: { stacked: true, beginAtZero: true }
                    },
                    plugins: {
                        legend: { display: true, position: 'top' }
                    }
                }
            });
        }

        async function loadHoroscopePreview() {
            try {
                const today = new Date().toISOString().split('T')[0];
                const role = teamData.team.primary_role || '';

                const response = await fetch(`/api/horoscope?date=${today}&team_id=${teamId}&role=${role}`);
                if (!response.ok) throw new Error('Failed to load horoscope');

                const data = await response.json();
                displayHoroscope(data.horoscope);
            } catch (error) {
                console.error('Error loading horoscope:', error);
                document.getElementById('horoscopePreview').innerHTML = '<p>Failed to load horoscope preview</p>';
            }
        }

        function displayHoroscope(horoscope) {
            if (!horoscope) {
                document.getElementById('horoscopePreview').innerHTML = '<p>No horoscope data available</p>';
                return;
            }

            const html = `
                <div class="info-row">
                    <span class="info-label">Overall Risk Level:</span>
                    <span>${horoscope.overall_risk_level}</span>
                </div>
                <div class="info-row">
                    <span class="info-label">Cosmic Advice:</span>
                    <span>${horoscope.cosmic_advice}</span>
                </div>
                <h3 style="margin-top: 20px;">Predictions:</h3>
                ${horoscope.predictions.map(pred => `
                    <div class="planetary-item">
                        <strong>${pred.planet}:</strong> ${pred.message}
                        <br><small>Category: ${pred.category} | Level: ${pred.level} | Confidence: ${(pred.confidence * 100).toFixed(0)}%</small>
                    </div>
                `).join('')}
            `;
            document.getElementById('horoscopePreview').innerHTML = html;

            // Display planetary events
            displayPlanetaryEvents(horoscope.planetary_summary);
        }

        function displayPlanetaryEvents(planetarySummary) {
            if (!planetarySummary) return;

            const html = planetarySummary.map(planet => `
                <div class="planetary-item">
                    <span class="planet-symbol">${planet.symbol}</span>
                    <strong>${planet.name}</strong> in ${planet.sign}
                    <br><small>${planet.domain} | Influence: ${planet.influence_strength}</small>
                </div>
            `).join('');
            document.getElementById('planetaryEvents').innerHTML = html;
        }

        function editTeam() {
            window.location.href = `/team/edit/${teamId}`;
        }

        function manageMembers() {
            alert('Member management UI coming soon!');
        }

        async function refreshHoroscope() {
            await loadHoroscopePreview();
        }

        // Load data on page load
        loadTeamData();
    </script>
</body>
</html>
