            };
            
            // Show horoscope card
            const horoscopeCard = document.getElementById('horoscope');
            const horoscopeTitle = document.getElementById('horoscopeTitle');
            const horoscopeLoading = document.getElementById('horoscopeLoading');
            
            horoscopeCard.style.display = 'block';
            horoscopeLoading.style.display = 'none';
            horoscopeTitle.textContent = '✨ Demo: Stained Glass Orrery';
            
            // Render the demo horoscope with orrery
            renderHoroscope(mockHoroscope, mockEphemeris);
        }
        
        function generateDeveloperInsights(insights, birthday) {
            if (!insights) return '';
            
            const outlookEmoji = {
                'favorable': '✨',
                'challenging': '⚡',
                'mixed': '🌗',
                'neutral': '⚪'
            };
            
            return `
                <div style="margin: 30px 0; padding: 20px; background: rgba(255, 255, 255, 0.1); border-radius: 15px;">
                    <h3 style="text-align: center; color: #ffd700; margin-bottom: 25px;">
                        ${birthday ? '🎂 Your Personal Developer Forecast' : '💻 Developer Forecast'}
                    </h3>
                    
                    <!-- Code Deployment Forecast -->
                    <div class="prediction ${insights.deployment_forecast.overall_outlook}" style="margin-bottom: 20px;">
                        <h4>${outlookEmoji[insights.deployment_forecast.overall_outlook]} How will your code deploy go today?</h4>
                        <div style="background: rgba(0,0,0,0.2); padding: 15px; border-radius: 8px; margin: 10px 0;">
                            <p style="font-style: italic; font-size: 1.1em; margin-bottom: 10px;">"${insights.deployment_forecast.cosmic_message}"</p>
                        </div>
                        <div style="margin: 15px 0;">
                            <strong>Cosmic Recommendations:</strong>
                            <ul style="margin: 10px 0; padding-left: 20px;">
                                ${insights.deployment_forecast.recommendations.map(rec => `<li>${rec}</li>`).join('')}
                            </ul>
                        </div>
                        <small>Confidence: ${Math.round(insights.deployment_forecast.confidence * 100)}%</small>
                    </div>
                    
                    <!-- On-Call Rotation Forecast -->
                    <div class="prediction ${insights.oncall_forecast.overall_outlook}">
                        <h4>${outlookEmoji[insights.oncall_forecast.overall_outlook]} How will your on-call rotation go today?</h4>
                        <div style="background: rgba(0,0,0,0.2); padding: 15px; border-radius: 8px; margin: 10px 0;">
                            <p style="font-style: italic; font-size: 1.1em; margin-bottom: 10px;">"${insights.oncall_forecast.cosmic_message}"</p>
                        </div>
                        <div style="margin: 15px 0;">
                            <strong>Cosmic Recommendations:</strong>
                            <ul style="margin: 10px 0; padding-left: 20px;">
                                ${insights.oncall_forecast.recommendations.map(rec => `<li>${rec}</li>`).join('')}
                            </ul>
                        </div>
                        <small>Confidence: ${Math.round(insights.oncall_forecast.confidence * 100)}%</small>
                    </div>
                    
                    ${birthday ? `
                        <div style="margin-top: 20px; padding: 15px; background: rgba(255, 215, 0, 0.1); border-radius: 8px; border: 1px solid rgba(255, 215, 0, 0.3);">
                            <h5 style="color: #ffd700; margin-bottom: 10px;">🌟 Personal Astrological Influence</h5>
                            <p style="font-size: 0.9em; opacity: 0.9;">
                                Your birth chart adds personal cosmic influences to today's predictions. 
                                The planetary positions at your birth interact with today's celestial energies to provide these personalized insights.
                            </p>
                        </div>
                    ` : ''}
                </div>
            `;
        }
        
        // Share functionality
        function generateShareURL(date, birthday) {
            const baseURL = window.location.origin + window.location.pathname;
            const params = new URLSearchParams();
            
            if (date) {
                params.append('date', date);
            }
            
            if (birthday) {
                params.append('birthday', birthday);
            }
            
            return `${baseURL}?${params.toString()}`;
        }
        
        async function copyShareURL(shareURL) {
            try {
                await navigator.clipboard.writeText(shareURL);
                showShareStatus('Link copied to clipboard! 📋', 'success');
            } catch (error) {
                console.error('Failed to copy:', error);
                showShareStatus('Unable to copy link. Please copy manually: ' + shareURL, 'error');
            }
        }
        
        function showShareStatus(message, type) {
            const statusElement = document.getElementById('shareStatus');
            if (statusElement) {
                statusElement.textContent = message;
                statusElement.style.color = type === 'success' ? '#4CAF50' : 
                                          type === 'warning' ? '#ffa502' : '#ff4757';
                
                // Clear the status after 3 seconds
                setTimeout(() => {
                    statusElement.textContent = '';
                }, 3000);
            }
        }
    </script>
</body>
</html>